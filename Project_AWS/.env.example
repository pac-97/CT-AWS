# Flask
FLASK_ENV=production
SECRET_KEY=change-me
PORT=5000

# AWS target
AWS_REGION=us-east-1

# Optional explicit SSO instance selection
# SSO_INSTANCE_ARN=arn:aws:sso:::instance/ssoins-xxxxxxxxxxxxxxxx
# IDENTITY_STORE_ID=d-xxxxxxxxxx

# Optional: comma-separated AWS account IDs to auto-provision on update
DEFAULT_PROVISION_ACCOUNTS=

# App audit DB path
APP_DB_PATH=data/control_plane.db

# Import inventory limit per service
INVENTORY_MAX_ITEMS=500
